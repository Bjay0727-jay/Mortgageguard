# ─── MortgageGuard — Environment Variables ───
# Copy this to .env.local and fill in your values

# Neon PostgreSQL (get from https://console.neon.tech)
DATABASE_URL=postgres://username:password@ep-xxx.us-east-2.aws.neon.tech/mortgageguard?sslmode=require

# Cloudflare (auto-configured by Wrangler, but needed for scripts)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Auth
JWT_SECRET=your-256-bit-secret-here

# Email (https://resend.com) — optional, not yet used
# RESEND_API_KEY=re_xxxxxxxxxxxx

# Stripe (https://stripe.com)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# DocuSign (Phase 2)
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_SECRET_KEY=
DOCUSIGN_ACCOUNT_ID=
